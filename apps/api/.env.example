ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_sales_agent
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
CORS_ORIGINS=http://localhost:3000

# Used to build links in transactional emails (verify-email, reset-password, invitations).
FRONTEND_URL=http://localhost:3000

# SMTP is optional in development: leave SMTP_HOST unset to skip sending real
# emails (verification/reset tokens are still returned in the API response's
# `meta.debug_*_token` field outside production). Set these to enable real
# delivery — any standard SMTP provider works (SendGrid, Mailtrap, SES SMTP,
# Gmail with an app password, etc.).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=salespilot.ai1@gmail.com
SMTP_PASSWORD=daga toqb emdc dchr
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=salespilot.ai1@gmail.com
SMTP_FROM_NAME=SalesPilot AI

# ─── AI providers ─────────────────────────────────────────────────────────────
# Platform-level fallback keys. Organizations can override per-org in
# AI Settings (stored encrypted on Integration rows, which take precedence).
# All optional — configure only the providers you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
# Ollama is a local/self-hosted server (no API key), e.g. http://localhost:11434
OLLAMA_BASE_URL=

AI_DEFAULT_PROVIDER=anthropic
AI_DEFAULT_MODEL=claude-sonnet-5
AI_MAX_RETRIES=3
AI_JOB_TIMEOUT_SECONDS=120
# Dev-only: run AI jobs inline in the API process instead of via the Celery
# worker (`celery -A app.workers.celery_app worker -Q ai,celery`). Never
# enable in production.
AI_EXECUTE_JOBS_EAGERLY=false

# Fernet key for encrypting stored provider credentials. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Falls back to a key derived from JWT_SECRET_KEY when unset (dev only).
CREDENTIALS_ENCRYPTION_KEY=
