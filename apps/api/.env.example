ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_sales_agent
REDIS_URL=redis://localhost:6379/0
JWT_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
CORS_ORIGINS=http://localhost:3000

# Used to build links in transactional emails (verify-email, reset-password, invitations).
FRONTEND_URL=http://localhost:3000

# SMTP is optional in development: leave SMTP_HOST unset to skip sending real
# emails (verification/reset tokens are still returned in the API response's
# `meta.debug_*_token` field outside production). Set these to enable real
# delivery — any standard SMTP provider works (SendGrid, Mailtrap, SES SMTP,
# Gmail with an app password, etc.).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=salespilot.ai1@gmail.com
SMTP_PASSWORD=daga toqb emdc dchr
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=salespilot.ai1@gmail.com
SMTP_FROM_NAME=SalesPilot AI
